# Minimal local template for the HWP batch live demo.
# Copy this file to .env.local and replace the placeholder key.

AI_PROVIDER=openai
AI_MODEL=gpt-4.1-mini
OPENAI_API_KEY=sk-...
NEXT_PUBLIC_APP_URL=http://localhost:6002

# Optional: keep the UI using the hosted draw.io embed.
# NEXT_PUBLIC_DRAWIO_BASE_URL=https://embed.diagrams.net
# NEXT_PUBLIC_DRAWIO_VIEWER_URL=https://viewer.diagrams.net
